# ─── Supabase (existing) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://026news.vercel.app

# ─── Gmail inbox integration (admin only) ──────────────────────────────────────
# 1. Create a Google Cloud project and enable the "Gmail API".
# 2. OAuth consent screen: add scopes gmail.readonly + gmail.send, type = External
#    (or Internal if you have Google Workspace).
# 3. Credentials -> OAuth 2.0 Client ID (type: Web application).
#    Authorized redirect URI = <NEXT_PUBLIC_APP_URL>/api/gmail/callback
# 4. Put the client ID / secret below, and a 32-char secret for encrypting tokens.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://026news.vercel.app/api/gmail/callback
GMAIL_ENCRYPTION_SECRET=
