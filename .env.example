# ═══════════════════════════════════════════════════════════════
#  026News — Environment Variables Reference
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ── Supabase (Required) ──────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App (Required) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=026News
NEXT_PUBLIC_SITE_DESCRIPTION=Breaking news, freelance journalism, and in-depth analysis from Africa and the world.

# ── Security (Required) ──────────────────────────────────────
# Used to protect admin sign-up endpoint
ADMIN_SIGNUP_SECRET=your_admin_signup_secret_min_16_chars
# Used to authenticate the cron job that fetches RSS feeds
CRON_SECRET=your_cron_secret_min_16_chars

# ── Vercel (CI/CD only — do not set locally) ─────────────────
# Set these as GitHub Actions secrets for auto-deployment
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id
# SUPABASE_PROJECT_REF=your_supabase_project_ref

# ── Stripe (Optional — for card payments) ────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── M-Pesa (Optional — for Kenya mobile payments) ────────────
# Found in: Safaricom Daraja Developer Portal
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_till_or_paybill_number
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://your-domain.vercel.app/api/payments/mpesa/callback

# ── PayPal (Optional — for international payments) ───────────
# Found in: PayPal Developer Dashboard → Apps & Credentials
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# ── Analytics (Optional) ─────────────────────────────────────
# PostHog — product analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google AdSense — for monetized articles
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-your_adsense_client_id

# ── Error Tracking (Optional) ────────────────────────────────
# Sentry — error monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=026news

# ── Development Utilities (Optional) ────────────────────────
# Allow additional origins for local dev (e.g. ngrok tunnel for M-Pesa callbacks)
NEXT_PUBLIC_ALLOWED_DEV_ORIGIN=
