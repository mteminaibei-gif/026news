# ─── Supabase (existing) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://026news.vercel.app

# ─── Gmail inbox integration (admin only) ──────────────────────────────────────
# 1. Create a Google Cloud project and enable the "Gmail API".
# 2. OAuth consent screen: add scopes gmail.readonly + gmail.send, type = External
#    (or Internal if you have Google Workspace).
# 3. Credentials -> OAuth 2.0 Client ID (type: Web application).
#    Authorized redirect URI = <NEXT_PUBLIC_APP_URL>/api/gmail/callback
# 4. Put the client ID / secret below, and a 32-char secret for encrypting tokens.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://026news.vercel.app/api/gmail/callback
GMAIL_ENCRYPTION_SECRET=

# ─── OpenAI (AI article enhancement) ────────────────────────────────────────────
# Used by the AI grammar/style/cohesion analyzer and rewrite/paraphrase engine.
# Get a key at https://platform.openai.com/api-keys
# Optional: override the default model (gpt-4o-mini) e.g. gpt-4o, gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── M-Pesa Daraja (Safaricom) ─────────────────────────────────────────────────
# These can be set here OR (preferred) configured in Admin → Settings → Monetization.
# The /api/payments/mpesa route reads from settings first, then falls back to env.
MPESA_ENV=sandbox                      # "sandbox" for testing, "production" for live
# Consumer Key & Secret from the Daraja portal (app credentials)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Business shortcode / till number + online passkey (LIPA NA MPESA)
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public callback URL Safaricom will POST STK push results to
MPESA_CALLBACK_URL=https://026news.vercel.app/api/payments/mpesa/callback
